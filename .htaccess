RewriteEngine On
RewriteBase /

# Prevent directory listing
Options -Indexes

# Set default pages for directories
DirectoryIndex index.php login.php dashboard.php admin-dashboard.php logs.php student-records.php account-management.php print-management.php documents-approval.php tor-grades.php course-creation.php create-batch.php subject-management.php profile.php enrollment.php

# Custom Error Pages
ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php

# Login/Logout redirects
RewriteRule ^login/?$ login/login.php [L]
RewriteRule ^logout/?$ login/logout.php [L]

# Dashboard redirects
RewriteRule ^dashboard/?$ dashboard/dashboard.php [L]
RewriteRule ^admin/?$ admin-tb5/admin-dashboard/admin-dashboard.php [L]

# Enrollment Pages
RewriteRule ^enrollment/?$ enrollment/enrollment.php [L]
RewriteRule ^enrollment/step-2/?$ enrollment/enrollment_page2.php [L]

# Admin Panel Pages
RewriteRule ^admin-tb5/login/?$ admin-tb5/login/login.php [L]
RewriteRule ^admin-tb5/logout/?$ admin-tb5/login/logout.php [L]
RewriteRule ^admin-tb5/admin-dashboard/?$ admin-tb5/admin-dashboard/admin-dashboard.php [L]
RewriteRule ^admin-tb5/logs/?$ admin-tb5/logs/logs.php [L]
RewriteRule ^admin-tb5/student-records/?$ admin-tb5/student-records/student-records.php [L]
RewriteRule ^admin-tb5/account-management/?$ admin-tb5/account-management/account-management.php [L]
RewriteRule ^admin-tb5/print-management/?$ admin-tb5/print-management/print-management.php [L]
RewriteRule ^admin-tb5/documents-approval/?$ admin-tb5/documents-approval/documents-approval.php [L]
RewriteRule ^admin-tb5/tor-grades/?$ admin-tb5/tor-grades/tor-grades.php [L]
RewriteRule ^admin-tb5/course-creation/?$ admin-tb5/course-creation/course-creation.php [L]
RewriteRule ^admin-tb5/create-batch/?$ admin-tb5/create-batch/create-batch.php [L]
RewriteRule ^admin-tb5/subject-management/?$ admin-tb5/subject-management/subject-management.php [L]
RewriteRule ^admin-tb5/profile/?$ admin-tb5/profile/profile.php [L]

# Hide .php extensions site-wide
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/([^/]+)$ $1/$2.php [L]

# Redirect if .php is accessed directly (EXCEPT specific files)
RewriteCond %{THE_REQUEST} ^GET.*\.php [NC]
RewriteCond %{REQUEST_URI} !^/(404|403|500|hash-password)\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/(404|403|500|hash-password)\.php$
RewriteCond %{REQUEST_URI} !/(login|register)/.*-handler\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/login/(login-handler|logout|refresh-session)\.php$
RewriteCond %{REQUEST_URI} !^/register/(register-handler|get-psgc-data)\.php$
RewriteCond %{REQUEST_URI} !^/enrollment/upload-documents-handler\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/account-management/(get-accounts|get-account-details|get-statistics|change-password|delete-account|export-accounts|approve-account|reject-account|toggle-status|add-account|assign-course-batch|get-batches-by-course)\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/documents-approval/(get-documents|get-courses-filter|fetch_notifications|approve-document|reject-document)\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/course-creation/(get-courses|get-course-details|save-course|delete-course|toggle-course-status)\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/tor-grades/(get-students|get-student-info|get-student-courses|get-tor-records|get-tor-statistics|generate-tor|view-tor|download-tor|delete-tor|regenerate-tor|create-directories|get-all-batches|get-all-courses|get-course-subjects|get-student-batches|get-students-by-filter|get-tor-students|generate-tor-csv|generate-tor-pdf|download-tor-csv|delete-tor)\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/create-batch/(get-batches|get-batch-statistics|get-courses-by-school|save-batch|delete-batch|get-batch-details)\.php$
RewriteCond %{REQUEST_URI} !^/admin-tb5/subject-management/(get-subjects|get-subject-details|save-subject|delete-subject|toggle-subject-status|get-courses-by-school|save-subjects-multi)\.php$
RewriteCond %{REQUEST_URI} !(admin-dashboard|logs|student-records|account-management|print-management|documents-approval|tor-grades|course-creation|create-batch|subject-management|profile|enrollment)\.php
RewriteRule ^(.*)\.php$ /$1 [R=301,L]